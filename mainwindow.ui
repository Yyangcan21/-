           </spacer>
          </item>
         </layout>
        </item>

        <!-- 进度条 -->
        <item>
         <layout class="QHBoxLayout">
          <item>
           <widget class="QLabel" name="label_progress">
            <property name="text"><string>训练进度：</string></property>
            <property name="minimumWidth"><number>70</number></property>
