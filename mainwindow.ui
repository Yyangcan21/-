        <!-- 中部：查询控制区 + 数据类型选择 -->
        <item>
         <layout class="QHBoxLayout" name="hLayout_dbQuery">
          <property name="spacing"><number>8</number></property>

          <item>
           <widget class="QLabel">
            <property name="text"><string>数据类型：</string></property>
           </widget>
          </item>
          <item>
           <widget class="QComboBox" name="combo_dbTable">
            <item><property name="text"><string>📋 训练记录</string></property></item>
            <item><property name="text"><string>🏷 标注统计</string></property></item>
            <item><property name="text"><string>⚡ 量化记录</string></property></item>
            <item><property name="text"><string>🔍 推理结果</string></property></item>
           </widget>
          </item>

          <item>
           <widget class="QLabel">
            <property name="text"><string>  状态筛选：</string></property>
           </widget>
          </item>
          <item>
           <widget class="QComboBox" name="combo_dbStatus">
            <item><property name="text"><string>全部</string></property></item>
            <item><property name="text"><string>completed</string></property></item>
            <item><property name="text"><string>failed</string></property></item>
            <item><property name="text"><string>stopped</string></property></item>
           </widget>
          </item>

          <item>
           <spacer>
            <property name="orientation">horizontal</property>
            <property name="sizeHint"><size><width>20</width><height>0</height></size></property>
           </spacer>
          </item>

          <item>
           <widget class="QPushButton" name="btn_dbRefresh">
            <property name="text"><string>🔄 刷新数据</string></property>
            <property name="minimumHeight"><number>32</number></property>
            <property name="styleSheet">
             <string>QPushButton { background-color: #2196F3; color: white; font-weight: bold; border-radius: 5px; padding: 0 12px; }
QPushButton:hover { background-color: #1976D2; }</string>
            </property>
           </widget>
          </item>

          <item>
           <widget class="QPushButton" name="btn_dbExport">
            <property name="text"><string>💾 导出 CSV</string></property>
            <property name="minimumHeight"><number>32</number></property>
            <property name="styleSheet">
             <string>QPushButton { background-color: #4CAF50; color: white; font-weight: bold; border-radius: 5px; padding: 0 12px; }
QPushButton:hover { background-color: #388E3C; }</string>
            </property>
           </widget>
          </item>

          <item>
           <widget class="QPushButton" name="btn_dbSaveAnnot">
            <property name="text"><string>📝 保存标注统计</string></property>
            <property name="minimumHeight"><number>32</number></property>
            <property name="toolTip"><string>将当前标注页签的统计信息保存到数据库</string></property>
            <property name="styleSheet">
             <string>QPushButton { background-color: #009688; color: white; font-weight: bold; border-radius: 5px; padding: 0 12px; }
QPushButton:hover { background-color: #00796B; }</string>
            </property>
           </widget>
          </item>

         </layout>
        </item>

        <!-- 数据表格 -->
        <item>
         <widget class="QTableWidget" name="tableWidget_dbResult">
          <property name="sizePolicy">
           <sizepolicy hsizetype="Expanding" vsizetype="Preferred">
            <horstretch>0</horstretch>
            <verstretch>1</verstretch>
           </sizepolicy>
          </property>
          <property name="maximumSize">
           <size><width>16777215</width><height>200</height></size>
          </property>
          <property name="alternatingRowColors"><bool>true</bool></property>
          <property name="selectionBehavior"><enum>QAbstractItemView::SelectRows</enum></property>
          <property name="editTriggers"><set>QAbstractItemView::NoEditTriggers</set></property>
          <property name="styleSheet">
           <string>QTableWidget { font-size: 12px; }
QHeaderView::section { background-color: #37474F; color: white; font-weight: bold; padding: 4px; border: none; }</string>
          </property>
         </widget>
        </item>



       </layout>
      </widget>

     </widget>
    </item>

   </layout>
  </widget>
