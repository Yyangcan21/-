                <property name="text"><string>推理次数</string></property>
                <property name="alignment"><set>Qt::AlignCenter</set></property>
                <property name="styleSheet"><string>font-size: 12px; color: #EF6C00;</string></property>
               </widget>
              </item>
             </layout>
            </widget>
           </item>

           <!-- 平均 mAP50 -->
           <item>
