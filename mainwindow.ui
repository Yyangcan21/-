      <!-- ===== 页签1：模型训练 ===== -->
      <widget class="QWidget" name="tab_training">
       <attribute name="title">
        <string>🚀 模型训练</string>
       </attribute>
       <layout class="QVBoxLayout" name="vLayout_training">
        <property name="spacing">
         <number>8</number>
        </property>
        <property name="leftMargin">
         <number>6</number>
        </property>
        <property name="topMargin">
         <number>6</number>
        </property>
        <property name="rightMargin">
         <number>6</number>
        </property>
        <property name="bottomMargin">
         <number>6</number>
        </property>

        <!-- 数据集 & 模型 -->
        <item>
         <widget class="QGroupBox" name="groupBox_data">
          <property name="title">
           <string>📁 数据集 &amp; 模型选择</string>
          </property>
          <layout class="QFormLayout" name="formLayout_data">
           <property name="leftMargin"><number>10</number></property>
           <property name="topMargin"><number>10</number></property>
           <property name="rightMargin"><number>10</number></property>
           <property name="bottomMargin"><number>10</number></property>
           <property name="horizontalSpacing"><number>10</number></property>
           <property name="verticalSpacing"><number>8</number></property>

           <item row="0" column="0">
            <widget class="QLabel" name="label_dataset">
             <property name="text"><string>数据集配置文件 (data.yaml)：</string></property>
            </widget>
           </item>
           <item row="0" column="1">
            <layout class="QHBoxLayout">
             <item>
              <widget class="QLineEdit" name="lineEdit_dataset">
               <property name="placeholderText"><string>请点击"浏览"按钮选择 data.yaml 文件...</string></property>
               <property name="readOnly"><bool>true</bool></property>
              </widget>
             </item>
             <item>
              <widget class="QPushButton" name="btn_selectDataset">
               <property name="text"><string>📂 浏览</string></property>
               <property name="minimumWidth"><number>80</number></property>
               <property name="maximumWidth"><number>80</number></property>
              </widget>
             </item>
            </layout>
           </item>

           <item row="1" column="0">
            <widget class="QLabel" name="label_model">
             <property name="text"><string>预训练模型：</string></property>
            </widget>
           </item>
           <item row="1" column="1">
            <widget class="QComboBox" name="combo_model">
             <item><property name="text"><string>yolov8n.pt（最快，适合测试）</string></property></item>
             <item><property name="text"><string>yolov8s.pt（小模型，平衡）</string></property></item>
             <item><property name="text"><string>yolov8m.pt（中等模型）</string></property></item>
             <item><property name="text"><string>yolov8l.pt（大模型，精度高）</string></property></item>
             <item><property name="text"><string>yolov8x.pt（最大模型，最慢）</string></property></item>
            </widget>
           </item>

           <item row="2" column="0">
            <widget class="QLabel" name="label_python">
             <property name="text"><string>Python 解释器路径：</string></property>
            </widget>
           </item>
           <item row="2" column="1">
            <layout class="QHBoxLayout">
             <item>
              <widget class="QLineEdit" name="lineEdit_python">
               <property name="text"><string>D:/Python/dog/.venv/Scripts/python.exe</string></property>
               <property name="placeholderText"><string>Python 可执行文件路径...</string></property>
              </widget>
             </item>
             <item>
              <widget class="QPushButton" name="btn_selectPython">
               <property name="text"><string>📂 浏览</string></property>
               <property name="minimumWidth"><number>80</number></property>
               <property name="maximumWidth"><number>80</number></property>
              </widget>
             </item>
            </layout>
           </item>

          </layout>
         </widget>
        </item>

        <!-- 训练参数 -->
        <item>
         <widget class="QGroupBox" name="groupBox_params">
          <property name="title">
           <string>⚙️ 训练参数</string>
          </property>
          <layout class="QGridLayout" name="gridLayout_params">
           <property name="leftMargin"><number>10</number></property>
           <property name="topMargin"><number>10</number></property>
           <property name="rightMargin"><number>10</number></property>
           <property name="bottomMargin"><number>10</number></property>
           <property name="horizontalSpacing"><number>20</number></property>
           <property name="verticalSpacing"><number>8</number></property>

           <item row="0" column="0">
            <widget class="QLabel" name="label_epoch">
             <property name="text"><string>训练轮数 (Epochs)：</string></property>
             <property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property>
            </widget>
           </item>
           <item row="0" column="1">
            <widget class="QSpinBox" name="spin_epoch">
             <property name="minimum"><number>1</number></property>
             <property name="maximum"><number>1000</number></property>
             <property name="value"><number>50</number></property>
            </widget>
           </item>
           <item row="0" column="2">
            <widget class="QLabel" name="label_batch">
             <property name="text"><string>批大小 (Batch Size)：</string></property>
             <property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property>
            </widget>
           </item>
           <item row="0" column="3">
            <widget class="QSpinBox" name="spin_batch">
             <property name="minimum"><number>1</number></property>
             <property name="maximum"><number>256</number></property>
             <property name="value"><number>16</number></property>
            </widget>
           </item>

           <item row="1" column="0">
            <widget class="QLabel" name="label_lr">
             <property name="text"><string>初始学习率 (lr0)：</string></property>
             <property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property>
            </widget>
           </item>
           <item row="1" column="1">
            <widget class="QDoubleSpinBox" name="spin_lr">
             <property name="decimals"><number>5</number></property>
             <property name="minimum"><double>0.00001</double></property>
             <property name="maximum"><double>1.00000</double></property>
             <property name="singleStep"><double>0.00100</double></property>
             <property name="value"><double>0.01000</double></property>
            </widget>
           </item>
           <item row="1" column="2">
            <widget class="QLabel" name="label_imgsz">
             <property name="text"><string>图像尺寸 (imgsz)：</string></property>
             <property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property>
            </widget>
           </item>
           <item row="1" column="3">
            <widget class="QComboBox" name="combo_imgsz">
             <item><property name="text"><string>320</string></property></item>
             <item><property name="text"><string>416</string></property></item>
             <item><property name="text"><string>640</string></property></item>
             <item><property name="text"><string>800</string></property></item>
             <item><property name="text"><string>1024</string></property></item>
            </widget>
           </item>

           <item row="2" column="0">
            <widget class="QLabel" name="label_device">
             <property name="text"><string>训练设备 (Device)：</string></property>
             <property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property>
            </widget>
           </item>
           <item row="2" column="1">
            <widget class="QComboBox" name="combo_device">
             <property name="currentIndex"><number>1</number></property>
             <item><property name="text"><string>cpu（CPU训练）</string></property></item>
             <item><property name="text"><string>0（GPU 0）</string></property></item>
             <item><property name="text"><string>1（GPU 1）</string></property></item>
            </widget>
           </item>
           <item row="2" column="2">
            <widget class="QLabel" name="label_workers">
             <property name="text"><string>数据加载线程 (Workers)：</string></property>
             <property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property>
            </widget>
           </item>
           <item row="2" column="3">
            <widget class="QSpinBox" name="spin_workers">
             <property name="minimum"><number>0</number></property>
             <property name="maximum"><number>16</number></property>
             <property name="value"><number>4</number></property>
            </widget>
           </item>

          </layout>
         </widget>
        </item>

        <!-- 控制按钮 -->
        <item>
         <layout class="QHBoxLayout" name="hLayout_ctrl">
          <item>
           <widget class="QPushButton" name="btn_train">
